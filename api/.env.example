# ====================================
# GEB Surrogacy API Environment Configuration
# ====================================

# Application Environment
NODE_ENV=production
PORT=3001

# Database Configuration
DB_PATH=./database.sqlite

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin Configuration
ADMIN_EMAIL=gebheritagagency@gmail.com
ADMIN_PASSWORD_HASH=your-secure-hash-here
ADMIN_URL=https://gebsurrogacy.com

# CORS Configuration
CORS_ORIGIN=https://gebsurrogacy.com,https://www.gebsurrogacy.com,http://localhost:5173

# Database options
# DB_PATH=./database.sqlite (default: current directory)

# Email Configuration for Gmail:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-factor authentication
# 3. Generate an App Password for "Mail"
# 4. Use that password below

# Notes:
# - ADMIN_PASSWORD_HASH: Generate using: crypto.createHash('sha256').update('your-password').digest('hex')
# - Never commit this file with real values
# - Always use strong, unique passwords
# - Rotate API keys and passwords regularly
